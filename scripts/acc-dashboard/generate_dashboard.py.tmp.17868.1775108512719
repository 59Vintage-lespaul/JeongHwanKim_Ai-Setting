def main():
    p=argparse.ArgumentParser(); p.add_argument("excel"); p.add_argument("--out",default=str(DEFAULT_OUT)); p.add_argument("--date",default=None)
    args=p.parse_args()
    path=Path(args.excel)
    if not path.exists(): print(f"파일 없음: {path}"); sys.exit(1)

    wb=openpyxl.load_workbook(str(path),read_only=True,data_only=True)
    sheets=wb.sheetnames; print(f"시트: {sheets}")
    def find(kw): return next((s for s in sheets if kw in s), None)

    cur_sheet  = find("2026") and next((s for s in sheets if "2026" in s and "전전주" not in s), None)
    pprev_sheet= find("전전주")
    prev_sheet = find("2025")
    if not cur_sheet: cur_sheet = sheets[0]
    if not prev_sheet: prev_sheet = sheets[1] if len(sheets) > 1 else sheets[0]

    print(f"[1/4] 현재주 시트 ({cur_sheet})...")
    items_cur = aggregate(load_sheet(wb[cur_sheet])); print(f"  -> {len(items_cur):,}개")

    print(f"[2/4] 전년 시트 ({prev_sheet})...")
    items_prev = aggregate(load_sheet(wb[prev_sheet])); print(f"  -> {len(items_prev):,}개")

    if pprev_sheet:
        print(f"[3/4] 전전주 시트 ({pprev_sheet})...")
        items_pprev = aggregate(load_sheet(wb[pprev_sheet])); print(f"  -> {len(items_pprev):,}개")
    else:
        print("[3/4] 전전주 시트 없음 — 스냅샷으로 대체")
        snaps = load_prev_snaps(date.today().strftime("%Y-%m-%d"), 1)
        items_pprev = []
        if snaps:
            items_pprev = [
                {"brand": k.split("|")[0], "season": k.split("|")[1],
                 "item_code": k.split("|")[2], "period_sale_qty": v["period_sale_qty"]}
                for k, v in snaps[0]["items"].items()
            ]
    wb.close()

    pprev_lookup = build_pprev_lookup(items_pprev)
    pprev_date = pprev_sheet or "스냅샷"

    ref_date = args.date or date.today().strftime("%Y-%m-%d"); print(f"기준일: {ref_date}")
    save_snapshot(items_cur, ref_date)

    print("[4/4] HTML 생성...")
    views = {vk: build_view(items_cur, items_prev, vk, pprev_lookup) for vk in VIEW_KEYS}
    out_dir = Path(args.out); out_dir.mkdir(parents=True, exist_ok=True)
    out_file = out_dir / f"board_acc-weekly_{ref_date}.html"
    build_html(ref_date, views, pprev_date, out_file)
    print(f"\n완료: {out_file}")

if __name__=="__main__": main()
