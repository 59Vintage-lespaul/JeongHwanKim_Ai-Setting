// ── 소팅 ─────────────────────────────────────────────────
function parseCell(text,type){{
  if(!text||text==="-"||text==="─")return type==="str"?"":Number.NEGATIVE_INFINITY;
  if(type==="pct"){{const m=text.match(/([\\d.]+)%/);return m?parseFloat(m[1]):-1;}}
  if(type==="num"){{
    const s=text.replace(/,/g,"").replace("원","").trim();
    if(s.endsWith("억원")||s.endsWith("억"))return parseFloat(s)*1e8;
    if(s.endsWith("만원")||s.endsWith("만"))return parseFloat(s)*1e4;
    return parseFloat(s)||0;
  }}
  return text.trim();
}}
function resetSortHeaders(){{
  document.querySelectorAll("#detailTable thead .sortable").forEach(h=>h.classList.remove("asc","desc"));
  sortState={{col:-1,dir:"asc"}};
}}

document.addEventListener("DOMContentLoaded",()=>{{
  document.querySelectorAll("#detailTable thead .sortable").forEach(th=>{{
    th.addEventListener("click",function(){{
      const col=parseInt(this.dataset.col),type=this.dataset.type;
      sortState.col===col ? sortState.dir=sortState.dir==="asc"?"desc":"asc"
                          : (sortState.col=col, sortState.dir=(type==="num"||type==="pct")?"desc":"asc");
      document.querySelectorAll("#detailTable thead .sortable").forEach(h=>h.classList.remove("asc","desc"));
      this.classList.add(sortState.dir);
      const tbody=document.getElementById("detailBody");
      Array.from(tbody.querySelectorAll("tr"))
        .sort((a,b)=>{{
          const at=(a.querySelectorAll("td")[col]||{{}}).textContent||"";
          const bt=(b.querySelectorAll("td")[col]||{{}}).textContent||"";
          const av=parseCell(at,type),bv=parseCell(bt,type);
          if(av===bv)return 0;
          const cmp=type==="str"?at.localeCompare(bt,"ko"):(av<bv?-1:1);
          return sortState.dir==="asc"?cmp:-cmp;
        }})
        .forEach(r=>tbody.appendChild(r));
      applySubFilter();
    }});
  }});
  renderAll();
}});
</script>
</body>
