    <div class="sec-header"><span>📋 전체 상세 (25FW · 26SS)</span></div>
    <div class="sec-body">
      <div class="sub-filter">
        <button class="sf-btn on" onclick="subFilter('all',this)">전체</button>
        <button class="sf-btn" onclick="subFilter('CAP',this)">모자</button>
        <button class="sf-btn" onclick="subFilter('BAG',this)">가방</button>
        <button class="sf-btn" onclick="subFilter('SHOES',this)">신발</button>
        <button class="sf-btn" onclick="subFilter('ACC',this)">액세서리</button>
        <button class="sf-btn" onclick="subFilter('26SS',this)" style="margin-left:8px">26SS</button>
        <button class="sf-btn" onclick="subFilter('25FW',this)">25FW</button>
      </div>
      <div class="tbl-wrap">
        <table class="data-table" id="detailTable">
          <thead><tr>
            <th class="sortable" data-col="0" data-type="str">브랜드<span class="sort-ic"></span></th>
            <th class="sortable" data-col="1" data-type="str">시즌<span class="sort-ic"></span></th>
            <th class="sortable" data-col="2" data-type="str">품번<span class="sort-ic"></span></th>
            <th class="sortable" data-col="3" data-type="str">품명<span class="sort-ic"></span></th>
            <th class="sortable" data-col="4" data-type="str">품목<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="5" data-type="num">택가<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="6" data-type="num">발주<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="7" data-type="num">누계입고<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="8" data-type="num">기간판매<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="9" data-type="num">기간매출<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="10" data-type="num">누계판매<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="11" data-type="num">누계매출<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="12" data-type="pct">소진율<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="13" data-type="num">총재고<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="14" data-type="num">물류<span class="sort-ic"></span></th>
            <th class="sortable num-r" data-col="15" data-type="num">매장<span class="sort-ic"></span></th>
          </tr></thead>
          <tbody id="detailBody"></tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<script>
const VIEWS       = {js_views};
const BL          = {{"커버낫":"커버낫","와키윌리":"와키윌리","리(LEE)":"리"}};
const BRAND_ORDER = ["커버낫","와키윌리","리(LEE)"];
const GL          = {{"CAP":"모자·헤드웨어","BAG":"가방","SHOES":"신발","ACC":"액세서리"}};

let currentView  = "종합";
let seasonTab    = "26SS";
let qtyMode      = "26ss";
let qtyLevel     = "group";
let spikeMode    = "26ss";
let subFilterVal = "all";
let sortState    = {{col:-1,dir:"asc"}};
let chartQty     = null;

// ── 유틸 ──────────────────────────────────────────────────
const fN = n => (!n&&n!==0)?"-":Math.round(n).toLocaleString("ko-KR");
const fA = n => {{
  if(!n&&n!==0)return"-";
  if(n>=1e8)return(n/1e8).toFixed(1)+"억원";
  if(n>=1e4)return Math.round(n/1e4)+"만원";
  return Math.round(n).toLocaleString()+"원";
}};
const stBadge = v => {{
  if(v===null||v===undefined)return'<span class="badge b-gry">-</span>';
  const c=v>=80?"b-red":v>=60?"b-org":v>=40?"b-yel":"b-grn";
  return`<span class="badge ${{c}}">${{v.toFixed(1)}}%</span>`;
}};
const stColor = v => v===null||v===undefined?"#999":v>=80?"#e53e3e":v>=60?"#dd6b20":v>=40?"#d69e2e":"#38a169";
const diffSpan = (change,pq) => {{
  if(pq===null||pq===undefined)return'<span class="new-tag">NEW</span>';
  if(change===null||change===undefined)return'<span class="fl">─</span>';
  const s=change>0?"+":"",c=change>0?"up":change<0?"dn":"fl",a=change>0?"▲":change<0?"▼":"─";
  return`<span class="${{c}}">${{a}} ${{s}}${{change.toFixed(1)}}%</span>`;
}};
const yMax = arr => {{
  const m=Math.max(...arr.filter(v=>v>0),1);
  const mg=Math.pow(10,Math.floor(Math.log10(m)));
  return Math.ceil(m/mg)*mg;
}};

// ── 탭 전환 ──────────────────────────────────────────────
function switchView(btn){{
  currentView=btn.getAttribute("data-view");
  document.querySelectorAll(".brand-tab").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  subFilterVal="all"; sortState={{col:-1,dir:"asc"}};
  renderAll();
}}
function setSeasonTab(btn){{
  seasonTab=btn.getAttribute("data-ssn");
  document.querySelectorAll(".season-tab").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  renderCards(VIEWS[currentView].summary);
}}
function setQtyMode(btn){{
  qtyMode=btn.getAttribute("data-qm");
  document.querySelectorAll("[data-qm]").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  renderQtyChart(VIEWS[currentView].chart);
  renderAmtChart(VIEWS[currentView].chart);
}}
function setQtyLevel(btn){{
  qtyLevel=btn.getAttribute("data-ql");
  document.querySelectorAll("[data-ql]").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  renderQtyChart(VIEWS[currentView].chart);
  renderAmtChart(VIEWS[currentView].chart);
}}
function setSpikeMode(btn){{
  spikeMode=btn.getAttribute("data-sm");
  document.querySelectorAll("[data-sm]").forEach(b=>b.classList.remove("active"));
  btn.classList.add("active");
  const v=VIEWS[currentView];
  renderSpikes(v.spikes);
  renderBagCompare(v.bag_compare);
}}

// ── 브랜드 브리핑 ─────────────────────────────────────────
function renderBrief(brief){{
  const brands=currentView==="종합"?BRAND_ORDER:[currentView];
  document.getElementById("briefArea").innerHTML=brands.map(b=>{{
    const d=brief?.[b];
    if(!d)return`<div class="brief-card signal-flat"><div class="brief-brand">${{BL[b]||b}}</div><div class="no-data">데이터 없음</div></div>`;
    const sigCls="signal-"+d.signal;
    const sigIcon=d.signal==="up"?"📈":d.signal==="down"?"📉":"➡️";
    const yoyBadgeCls=d.yoy_pct===null?"bb-yoy-flat":d.yoy_pct>=10?"bb-yoy-up":d.yoy_pct<=-10?"bb-yoy-dn":"bb-yoy-flat";
    const yoyText=d.yoy_pct===null?"YoY -":`YoY ${{d.yoy_pct>=0?"+":""}}${{d.yoy_pct}}%`;
    const wowText=d.wow_pct===null?"WoW -":`WoW ${{d.wow_pct>=0?"+":""}}${{d.wow_pct}}%`;
    const alarmBadge=d.alarm_cnt>0?`<span class="brief-badge bb-alarm">⚠️ QR ${{d.alarm_cnt}}건</span>`:"";
    const discFmt=v=>v===null?"-":`${{v}}%`;
    const n=d.new, c=d.carry, a=d.all;
    return`<div class="brief-card ${{sigCls}}">
      <span class="brief-signal-icon">${{sigIcon}}</span>
      <div class="brief-brand">${{d.brand}}</div>
      <div><span class="brief-qty">${{fN(a.qty)}}</span><span class="brief-qty-unit">개</span>
           <span style="font-size:11px;color:#718096;margin-left:6px">${{fA(a.amt)}}</span></div>
      <table class="brief-seg-table">
        <thead><tr>
          <th></th><th>수량</th><th>TAG금액</th><th>실판금액</th><th>할인율</th>
        </tr></thead>
        <tbody>
          <tr class="bst-new">
            <td>신상(26SS)</td>
            <td>${{fN(n.qty)}}개</td>
            <td>${{fA(n.tag_amt)}}</td>
            <td>${{fA(n.amt)}}</td>
            <td>${{discFmt(n.disc)}}</td>
          </tr>
          <tr class="bst-carry">
            <td>이월</td>
            <td>${{fN(c.qty)}}개</td>
            <td>${{fA(c.tag_amt)}}</td>
            <td>${{fA(c.amt)}}</td>
            <td>${{discFmt(c.disc)}}</td>
          </tr>
          <tr class="bst-total">
            <td>합계</td>
            <td>${{fN(a.qty)}}개</td>
            <td>${{fA(a.tag_amt)}}</td>
            <td>${{fA(a.amt)}}</td>
            <td>${{discFmt(a.disc)}}</td>
          </tr>
        </tbody>
      </table>
      <div class="brief-badges">
        <span class="brief-badge ${{yoyBadgeCls}}">${{yoyText}}</span>
        <span class="brief-badge bb-wow">${{wowText}}</span>
        ${{alarmBadge}}
      </div>
      <div class="brief-divider"></div>
      <div class="brief-meta">
        <span class="lbl">최다판매 품목</span> ${{d.top_grp||"-"}} (${{fN(d.top_grp_qty)}}개)<br>
        <span class="lbl">최다판매 품번</span> ${{d.top_item_code||"-"}} ${{d.top_item_name?`— ${{d.top_item_name}}`:""}}<br>
        <span style="margin-left:12px;color:#718096">${{fN(d.top_item_qty)}}개</span>
      </div>
    </div>`;
  }}).join("");
}}

// ── 전체 렌더 ─────────────────────────────────────────────
function renderAll(){{
  const v=VIEWS[currentView];
  renderBrief(v.brief);
  renderInsight(v.insight);
  renderCards(v.summary);
  renderQtyChart(v.chart);
  renderAmtChart(v.chart);
  renderMatrix(v.matrix);
  renderAlarms(v.alarms);
  renderSpikes(v.spikes);
  renderBagCompare(v.bag_compare);
  renderDetail(v.detail);
  resetSubFilter(); resetSortHeaders();
}}

// ── 카드 ─────────────────────────────────────────────────
function renderCards(summary){{
  const brands=currentView==="종합"?BRAND_ORDER:[currentView];
  document.getElementById("cardsArea").innerHTML=brands.map(b=>{{
    const s=summary[seasonTab]?.[b];
    if(!s)return`<div class="brand-card"><div class="bc-label">${{BL[b]||b}}</div><div class="no-data">데이터 없음</div></div>`;
    return`<div class="brand-card">
      <div class="bc-label">${{s.label}}</div>
      <div><span class="bc-big">${{fN(s.period_qty)}}</span><span class="bc-unit">개</span></div>
      <div class="bc-sub">${{fA(s.period_amt)}}</div>
      <div class="bc-div"></div>
      <div class="bc-row"><span class="lbl-sm">누계소진율</span>
        <span class="val-sm" style="color:${{stColor(s.st)}}">${{s.st!==null?s.st.toFixed(1)+"%":"-"}}</span></div>
      <div class="bc-row"><span class="lbl-sm">총재고</span>
        <span class="val-sm">${{fN(s.total_stock)}}개</span></div>
    </div>`;
  }}).join("");
}}

// ── 기간판매 차트 ─────────────────────────────────────────
function renderQtyChart(chart){{
  const key=qtyMode==="26ss"?"qty_26ss":"qty_all";
  const d=chart[key][qtyLevel];
  if(chartQty)chartQty.destroy();
  const ym=yMax([...d.cur,...d.prev]);
  chartQty=new Chart(document.getElementById("chartQty"),{{
    type:"bar",
    data:{{labels:d.labels,datasets:[
      {{label:"현년",data:d.cur,backgroundColor:"rgba(49,130,206,.85)",borderColor:"#2b6cb0",borderWidth:1,borderRadius:3}},
      {{label:"전년",data:d.prev,backgroundColor:"rgba(160,174,192,.5)",borderColor:"#a0aec0",borderWidth:1,borderRadius:3}},
    ]}},
    options:{{
      responsive:true,maintainAspectRatio:false,
      plugins:{{legend:{{position:"bottom",labels:{{font:{{size:11}},boxWidth:12,padding:8}}}},
               tooltip:{{callbacks:{{label:c=>c.dataset.label+": "+c.parsed.y.toLocaleString()+"개"}}}}}},
      scales:{{
        x:{{ticks:{{font:{{size:11}}}},grid:{{display:false}}}},
        y:{{min:0,max:ym,ticks:{{stepSize:ym/5,callback:v=>v.toLocaleString(),font:{{size:11}}}},grid:{{color:"#f0f0f0"}}}}
      }}
    }}
  }});
  const tc=d.cur.reduce((a,b)=>a+b,0),tp=d.prev.reduce((a,b)=>a+b,0);
  const pct=tp>0?((tc-tp)/tp*100).toFixed(1):"-";
  const sign=parseFloat(pct)>=0?"+":"";
  document.getElementById("qtyNote").textContent=`현년 ${{tc.toLocaleString()}}개 / 전년 ${{tp.toLocaleString()}}개 · YoY ${{sign}}${{pct}}%`;
}}

// ── 실판매금액 차트 ───────────────────────────────────────
let chartAmt=null;
function renderAmtChart(chart){{
  const key=qtyMode==="26ss"?"amt_26ss":"amt_all";
  const d=chart[key][qtyLevel];
  if(chartAmt)chartAmt.destroy();
  const ym=yMax([...d.cur,...d.prev]);
  chartAmt=new Chart(document.getElementById("chartAmt"),{{
    type:"bar",
    data:{{labels:d.labels,datasets:[
      {{label:"현년",data:d.cur,backgroundColor:"rgba(56,161,105,.85)",borderColor:"#276749",borderWidth:1,borderRadius:3}},
      {{label:"전년",data:d.prev,backgroundColor:"rgba(160,174,192,.5)",borderColor:"#a0aec0",borderWidth:1,borderRadius:3}},
    ]}},
    options:{{
      responsive:true,maintainAspectRatio:false,
      plugins:{{legend:{{position:"bottom",labels:{{font:{{size:11}},boxWidth:12,padding:8}}}},
               tooltip:{{callbacks:{{label:c=>c.dataset.label+": "+c.parsed.y.toLocaleString()+"만원"}}}}}},
      scales:{{
        x:{{ticks:{{font:{{size:11}}}},grid:{{display:false}}}},
        y:{{min:0,max:ym,ticks:{{stepSize:ym/5,callback:v=>v.toLocaleString(),font:{{size:11}}}},grid:{{color:"#f0f0f0"}}}}
      }}
    }}
  }});
  const tc=d.cur.reduce((a,b)=>a+b,0),tp=d.prev.reduce((a,b)=>a+b,0);
  const pct=tp>0?((tc-tp)/tp*100).toFixed(1):"-";
