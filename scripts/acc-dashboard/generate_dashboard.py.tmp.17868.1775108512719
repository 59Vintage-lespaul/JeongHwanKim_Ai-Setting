ALARM_SEASONS   = {"25FW","26SS"}

COL = dict(
    brand=2, season=6, item_code=8, item_name=9, list_price=13,
    order_qty=21, period_in_qty=26, total_in_qty=31,
    period_sale_qty=36, period_sale_amt=37,
    period_first_amt=38,   # 기간 최초판매금액 (할인 전)
    period_net_amt=41,     # 기간 실판매금액 (할인 후 실제)
    total_sale_qty=42, total_sale_amt=43,
    total_net_amt=47,      # 누계 실판매금액
    logistics_stock=49, store_stock=53, total_stock=58,
)

def si(v):
    try: return int(v) if v else 0
    except: return 0
def sf(v):
    try: return float(v) if v else 0.0
    except: return 0.0
def stpct(sale, inc):
    if inc <= 0: return None
    return round(min(sale / inc * 100, 100.0), 1)
def nb(b):
    if not b: return None
    b = str(b).strip()
    return "리(LEE)" if b in ("리(LEE)","리 (LEE)","리") else b
def itype(code):
    code = str(code) if code else ""
    return code[6:8] if len(code) >= 8 else "??"

def infer_season(code):
    """품번 5~6번째 자리(0-indexed 4~5)로 시즌 추론 — 시즌 칸이 비었을 때 fallback.
    01·02 → SS, 03·04 → FW. 연도는 3~4번째 자리(0-indexed 2~3)에서 읽음."""
    if len(code) < 6: return ""
    year = code[2:4]
    sc   = code[4:6]
    if sc in ("01", "02"): return f"{year}SS"
    if sc in ("03", "04"): return f"{year}FW"
    return ""

def load_sheet(ws):
    rows = ws.iter_rows(values_only=True)
    next(rows); next(rows)
    skus = []
    for row in rows:
        brand = nb(row[COL["brand"]])
        if not brand or brand not in BRAND_ORDER: continue
        code = str(row[COL["item_code"]] or "")
        if len(code) < 8: continue
        it = itype(code)
        if it not in ITEM_TO_GROUP: continue  # 어패럴·기타 품목 제외
        raw_season = str(row[COL["season"]] or "").strip()
        season = raw_season if raw_season else infer_season(code)
        skus.append({
            "brand": brand, "season": season,
            "item_code": code[:10], "item_name": str(row[COL["item_name"]] or "").strip(),
            "item_type": it, "group": ITEM_TO_GROUP.get(it,"기타"),
            "list_price": si(row[COL["list_price"]]), "order_qty": si(row[COL["order_qty"]]),
            "period_in_qty": si(row[COL["period_in_qty"]]), "total_in_qty": si(row[COL["total_in_qty"]]),
            "period_sale_qty": si(row[COL["period_sale_qty"]]), "period_sale_amt": sf(row[COL["period_sale_amt"]]),
            "period_first_amt": sf(row[COL["period_first_amt"]]),
            "period_net_amt":   sf(row[COL["period_net_amt"]]),
            "total_sale_qty": si(row[COL["total_sale_qty"]]), "total_sale_amt": sf(row[COL["total_sale_amt"]]),
            "total_net_amt": sf(row[COL["total_net_amt"]]),
            "logistics_stock": si(row[COL["logistics_stock"]]), "store_stock": si(row[COL["store_stock"]]),
            "total_stock": si(row[COL["total_stock"]]),
        })
    return skus

def aggregate(skus):
    agg = defaultdict(lambda: dict(
        brand="",season="",item_code="",item_name="",item_type="",group="",list_price=0,
        order_qty=0,period_in_qty=0,total_in_qty=0,
        period_sale_qty=0,period_sale_amt=0.0,
        period_first_amt=0.0,period_net_amt=0.0,
        total_sale_qty=0,total_sale_amt=0.0,total_net_amt=0.0,
        logistics_stock=0,store_stock=0,total_stock=0,
    ))
    num = ["order_qty","period_in_qty","total_in_qty","period_sale_qty","period_sale_amt",
           "period_first_amt","period_net_amt",
           "total_sale_qty","total_sale_amt","total_net_amt",
           "logistics_stock","store_stock","total_stock"]
    for s in skus:
        k = (s["brand"],s["season"],s["item_code"])
        d = agg[k]
        d.update({f: s[f] for f in ("brand","season","item_code","item_name","item_type","group")})
        d["list_price"] = s["list_price"] or d["list_price"]
        for f in num: d[f] += s[f]
    result = list(agg.values())
    for d in result: d["st"] = stpct(d["total_sale_qty"], d["total_in_qty"])
    return result

def save_snapshot(items, ref_date):
    snap = {"date": ref_date, "items": {
        f"{d['brand']}|{d['season']}|{d['item_code']}": {"period_sale_qty": d["period_sale_qty"]}
        for d in items
    }}
    (SNAPSHOT_DIR / f"snapshot_{ref_date}.json").write_text(
        json.dumps(snap, ensure_ascii=False, indent=2), encoding="utf-8")

def load_prev_snaps(cur_date, n=2):
    snaps = sorted(SNAPSHOT_DIR.glob("snapshot_*.json"), reverse=True)
    res = []
    for s in snaps:
        d = s.stem.replace("snapshot_","")
        if d != cur_date:
            res.append(json.loads(s.read_text(encoding="utf-8")))
            if len(res) >= n: break
    return res

# ── 계산 ──────────────────────────────────────────────────
def fil_b(items, brand): return items if brand == "종합" else [d for d in items if d["brand"] == brand]
def fil_s(items, seasons): return [d for d in items if d["season"] in seasons]

def compute_summary(items):
    result = {}
    for s in SUMMARY_SEASONS:
        result[s] = {}
        for b in BRAND_ORDER:
            fil = [d for d in items if d["brand"] == b and d["season"] == s]
            if not fil: result[s][b] = None; continue
            ts, ti = sum(d["total_sale_qty"] for d in fil), sum(d["total_in_qty"] for d in fil)
            result[s][b] = {
                "label": BRAND_LABELS.get(b, b),
                "period_qty": sum(d["period_sale_qty"] for d in fil),
                "period_amt": round(sum(d["period_sale_amt"] for d in fil)),
                "total_sale": ts, "total_in": ti,
                "total_stock": sum(d["total_stock"] for d in fil),
                "st": stpct(ts, ti),
            }
    return result

def _agg_group(items, seasons=None):
    d = defaultdict(lambda: {"period_qty":0,"period_amt":0.0,"total_sale":0,"total_in":0})
    for it in items:
        if seasons and it["season"] not in seasons: continue
        d[it["group"]]["period_qty"]  += it["period_sale_qty"]
        d[it["group"]]["period_amt"]  += it["period_net_amt"]   # 실판매금액 기준
        d[it["group"]]["total_sale"]  += it["total_sale_qty"]
        d[it["group"]]["total_in"]    += it["total_in_qty"]
    return d

def _agg_type(items, seasons=None):
    d = defaultdict(lambda: {"period_qty":0,"period_amt":0.0,"total_sale":0,"total_in":0})
    for it in items:
        if seasons and it["season"] not in seasons: continue
        d[it["item_type"]]["period_qty"]  += it["period_sale_qty"]
        d[it["item_type"]]["period_amt"]  += it["period_net_amt"]   # 실판매금액 기준
        d[it["item_type"]]["total_sale"]  += it["total_sale_qty"]
        d[it["item_type"]]["total_in"]    += it["total_in_qty"]
    return d

def _qty_chart(cd, pd_, keys, lbl):
    labels, cur, prev = [], [], []
    for k in keys:
        c, p = cd.get(k,{"period_qty":0}), pd_.get(k,{"period_qty":0})
        if c["period_qty"] == 0 and p["period_qty"] == 0: continue
        labels.append(lbl(k)); cur.append(c["period_qty"]); prev.append(p["period_qty"])
    return {"labels": labels, "cur": cur, "prev": prev}

def _amt_chart(cd, pd_, keys, lbl):
    """실판매금액 YoY 차트 데이터 — 만원 단위"""
    labels, cur, prev = [], [], []
    for k in keys:
        c, p = cd.get(k,{"period_amt":0.0}), pd_.get(k,{"period_amt":0.0})
        ca, pa = round(c["period_amt"]/10000), round(p["period_amt"]/10000)
        if ca == 0 and pa == 0: continue
        labels.append(lbl(k)); cur.append(ca); prev.append(pa)
    return {"labels": labels, "cur": cur, "prev": prev}

def compute_chart(ic, ip):
    gc26=_agg_group(ic,{"26SS"}); gp26=_agg_group(ip,{"25SS"})
    gcA =_agg_group(ic,{"26SS","25FW"}); gpA=_agg_group(ip,{"25SS","24FW"})
    tc26=_agg_type(ic,{"26SS"}); tp26=_agg_type(ip,{"25SS"})
    tcA =_agg_type(ic,{"26SS","25FW"}); tpA=_agg_type(ip,{"25SS","24FW"})
    gk=list(GROUPS.keys())
    ak=sorted(set(list(tcA.keys())+list(tpA.keys())))
    gl=lambda k: GROUP_LABELS[k]; tl=lambda k: ITEM_NAMES.get(k,k)
    return {
        "qty_26ss": {"group":_qty_chart(gc26,gp26,gk,gl), "type":_qty_chart(tc26,tp26,ak,tl)},
        "qty_all":  {"group":_qty_chart(gcA,gpA,gk,gl),   "type":_qty_chart(tcA,tpA,ak,tl)},
        "amt_26ss": {"group":_amt_chart(gc26,gp26,gk,gl), "type":_amt_chart(tc26,tp26,ak,tl)},
        "amt_all":  {"group":_amt_chart(gcA,gpA,gk,gl),   "type":_amt_chart(tcA,tpA,ak,tl)},
    }

def compute_matrix(items):
    mat = defaultdict(lambda: defaultdict(lambda: {"qty":0,"total_sale":0,"total_in":0}))
    for d in fil_s(items, MATRIX_SEASONS):
        mat[d["group"]][d["brand"]]["qty"]        += d["period_sale_qty"]
        mat[d["group"]][d["brand"]]["total_sale"] += d["total_sale_qty"]
        mat[d["group"]][d["brand"]]["total_in"]   += d["total_in_qty"]
    result = {}
    for g in GROUPS:
        result[g] = {}
        for b in BRAND_ORDER:
            c = mat[g][b]
            result[g][b] = {"qty": c["qty"], "st": stpct(c["total_sale"], c["total_in"])}
    return result

def _is_co_c_prefix(d):
    return d["brand"] == "커버낫" and len(d["item_code"]) >= 10 and d["item_code"][8].upper() == "C"

def compute_alarms(items, stock_thr=30):
    """리오더 알람: 소진율 <70% · 최근 판매 있음 · 재고 부족 · 커버낫 C-prefix 제외
    소진율 >=70%는 의도적 소진 결정으로 간주하여 제외."""
    res = []
    for d in fil_s(items, ALARM_SEASONS):
        if _is_co_c_prefix(d): continue
        if d["st"] is None: continue
        if d["st"] >= 70: continue          # 판매율 70%↑ 제외 (이유 있어서 QR 안함)
        if d["period_sale_qty"] <= 0: continue  # 최근 판매 없으면 제외
        stock_low = (d["total_stock"] <= stock_thr or
                     (d["order_qty"] > 0 and d["total_stock"] / d["order_qty"] <= 0.05))
        if stock_low:
            res.append({k: d[k] for k in (
                "brand","season","item_code","item_name","item_type",
                "order_qty","total_in_qty","total_sale_qty","st",
                "total_stock","logistics_stock","store_stock","period_sale_qty")})
    res.sort(key=lambda x: (-x["st"], x["total_stock"]))
    return res[:40]

def build_pprev_lookup(items_pprev):
    """전전주 아이템 → period_sale_qty 조회 딕셔너리"""
    return {
        f"{d['brand']}|{d['season']}|{d['item_code']}": d["period_sale_qty"]
        for d in items_pprev
    }

def _spike_row(d, pprev_lookup):
    """판매 상위 행 생성 — 전전주 대비 비교"""
    key = f"{d['brand']}|{d['season']}|{d['item_code']}"
    pq  = pprev_lookup.get(key, None)
    chg = round((d["period_sale_qty"] - pq) / pq * 100, 1) if pq and pq > 0 else None
    return {
        "brand": d["brand"], "season": d["season"],
        "item_code": d["item_code"], "item_name": d["item_name"],
        "item_type": ITEM_NAMES.get(d["item_type"], d["item_type"]),
        "period_qty": d["period_sale_qty"], "period_amt": round(d["period_sale_amt"]),
        "pprev_qty": pq, "change": chg, "st": d["st"], "total_stock": d["total_stock"],
    }

def compute_spikes(items, pprev_lookup=None, top_n=25):
    """이번기간 판매 상위 + 전전주 대비 증감"""
    pi = pprev_lookup or {}
    def top(seasons):
        sel = [d for d in fil_s(items, seasons) if d["period_sale_qty"] > 0]
        sel.sort(key=lambda x: -x["period_sale_qty"])
        return [_spike_row(d, pi) for d in sel[:top_n]]
    return {"26ss": top({"26SS"}), "all": top({"26SS","25FW"})}

def compute_wow_changes(items_cur, pprev_lookup, surge_thr=40, drop_thr=-40):
    """전전주 대비 판매 급변 품목 감지 — 급증/급감 각 최대 20개"""
    surge, drop = [], []
    for d in fil_s(items_cur, ALARM_SEASONS):
        if d["period_sale_qty"] <= 0: continue
        key = f"{d['brand']}|{d['season']}|{d['item_code']}"
        pq = pprev_lookup.get(key)
        if not pq or pq <= 0: continue
        chg = round((d["period_sale_qty"] - pq) / pq * 100, 1)
        row = {
            "brand": d["brand"], "season": d["season"],
            "item_code": d["item_code"], "item_name": d["item_name"],
            "item_type": ITEM_NAMES.get(d["item_type"], d["item_type"]),
            "period_qty": d["period_sale_qty"], "pprev_qty": pq,
            "change": chg, "st": d["st"], "total_stock": d["total_stock"],
            "qr_candidate": d["st"] is not None and d["st"] < 70,
        }
        if chg >= surge_thr:
            surge.append(row)
        elif chg <= drop_thr:
            drop.append(row)
    surge.sort(key=lambda x: -x["change"])
    drop.sort(key=lambda x: x["change"])
    return {"surge": surge[:20], "drop": drop[:20]}

def _bag_row(d):
    return {
        "brand": BRAND_LABELS.get(d["brand"], d["brand"]),
        "item_code": d["item_code"], "item_name": d["item_name"],
        "item_type": ITEM_NAMES.get(d["item_type"], d["item_type"]),
        "season": d["season"],
        "period_qty": d["period_sale_qty"],
        "total_qty": d["total_sale_qty"],
        "st": d["st"], "total_stock": d["total_stock"],
    }

def compute_bag_compare(ic, ip, top_n=20):
    """가방 이번기간 판매상위 현년 vs 전년 비교"""
    def top(items, seasons):
        sel = [d for d in items if d["group"]=="BAG" and d["season"] in seasons and d["total_in_qty"] > 0]
        sel.sort(key=lambda x: -x["period_sale_qty"])
        return [_bag_row(d) for d in sel[:top_n]]
    return {
        "cur_26ss": top(ic, {"26SS"}),
        "cur_all":  top(ic, {"26SS","25FW"}),
        "prev_26ss": top(ip, {"25SS"}),
        "prev_all":  top(ip, {"25SS","24FW"}),
    }

def compute_detail(items):
    active = [d for d in fil_s(items, {"26SS","25FW"}) if d["total_in_qty"] > 0]
    active.sort(key=lambda x: (x["brand"], x["group"], -(x["st"] or 0)))
    return [{
        "brand": BRAND_LABELS.get(d["brand"],d["brand"]), "brand_raw": d["brand"],
        "season": d["season"], "group": d["group"],
        "item_code": d["item_code"], "item_name": d["item_name"],
        "item_type": ITEM_NAMES.get(d["item_type"],d["item_type"]),
        "list_price": d["list_price"], "order_qty": d["order_qty"],
        "total_in": d["total_in_qty"], "period_qty": d["period_sale_qty"],
        "period_amt": round(d["period_sale_amt"]), "total_qty": d["total_sale_qty"],
        "total_amt": round(d["total_sale_amt"]), "st": d["st"],
        "total_stock": d["total_stock"], "log_stock": d["logistics_stock"], "str_stock": d["store_stock"],
    } for d in active]

def compute_brief(ic, ip, brand, pprev_lookup):
    """브랜드별 주간 매출 브리핑 — 신상(26SS)·이월 분리 + TAG/실판/할인율"""
    def _seg(items):
        qty       = sum(d["period_sale_qty"]   for d in items)
        first_amt = round(sum(d["period_first_amt"] for d in items))  # 최초판매금액 (할인 전)
        net_amt   = round(sum(d["period_net_amt"]   for d in items))  # 실판매금액 (할인 후)
        disc      = round((first_amt - net_amt) / first_amt * 100, 1) if first_amt > 0 else None
        return {"qty": qty, "tag_amt": first_amt, "amt": net_amt, "disc": disc}

    result = {}
    for b in (BRAND_ORDER if brand == "종합" else [brand]):
        fc_new   = [d for d in ic if d["brand"] == b and d["season"] == "26SS"]
        fc_carry = [d for d in ic if d["brand"] == b and d["season"] != "26SS"]
        fc_all   = fc_new + fc_carry
        fp       = [d for d in ip if d["brand"] == b and d["season"] == "25SS"]
        if not fc_all:
            result[b] = None
            continue

        new_s   = _seg(fc_new)
        carry_s = _seg(fc_carry)
        all_s   = _seg(fc_all)

        # YoY (26SS vs 25SS)
        prev_yr_qty = sum(d["period_sale_qty"] for d in fp)
        yoy_pct = round((new_s["qty"] - prev_yr_qty) / prev_yr_qty * 100, 1) if prev_yr_qty > 0 else None

        # WoW vs 전전주 (26SS+이월 전체 기준)
        wow_qty = sum(
            pprev_lookup.get(f"{d['brand']}|{d['season']}|{d['item_code']}", 0)
            for d in fc_all
        )
        wow_pct = round((all_s["qty"] - wow_qty) / wow_qty * 100, 1) if wow_qty > 0 else None

        # 최다 판매 그룹 (전체)
        grp_qty = defaultdict(int)
        for d in fc_all:
            grp_qty[d["group"]] += d["period_sale_qty"]
        top_grp = max(grp_qty, key=grp_qty.get) if grp_qty else None
        top_grp_qty = grp_qty.get(top_grp, 0)

        # 최다 판매 품번 (신상 기준)
        top_item = max(fc_new, key=lambda x: x["period_sale_qty"]) if fc_new else None

        # 리오더 대상 (전체)
        alarm_cnt = len([d for d in compute_alarms(fc_all) if d])
        signal = "up" if (yoy_pct or 0) >= 10 else "down" if (yoy_pct or 0) <= -10 else "flat"

        result[b] = {
            "brand": BRAND_LABELS.get(b, b),
            "all": all_s, "new": new_s, "carry": carry_s,
            "prev_yr_qty": prev_yr_qty, "yoy_pct": yoy_pct,
            "wow_qty": wow_qty, "wow_pct": wow_pct,
            "top_grp": GROUP_LABELS.get(top_grp, top_grp) if top_grp else None,
            "top_grp_qty": top_grp_qty,
            "top_item_code": top_item["item_code"] if top_item else None,
            "top_item_name": top_item["item_name"] if top_item else None,
            "top_item_qty": top_item["period_sale_qty"] if top_item else 0,
            "alarm_cnt": alarm_cnt,
            "signal": signal,
        }
    return result

def compute_insight(ic, ip, brand, pprev_lookup=None):
    """브랜드별 매출 특이사항 — 데이터 기반 차별화 분석 (최대 6개)"""
    # 전체 브랜드 집계 (비교 기준용)
    all_cur_qty = sum(d["period_sale_qty"] for d in ic if d["season"] == "26SS")
    all_prev_qty = sum(d["period_sale_qty"] for d in ip if d["season"] == "25SS")

    result = {}
    for b in (BRAND_ORDER if brand == "종합" else [brand]):
        fc_new   = [d for d in ic if d["brand"] == b and d["season"] == "26SS"]
        fc_carry = [d for d in ic if d["brand"] == b and d["season"] != "26SS"]
        fc_all   = fc_new + fc_carry
        fp_new   = [d for d in ip if d["brand"] == b and d["season"] == "25SS"]
        if not fc_all:
            result[b] = []
            continue

        pts = []

        cur_tot  = sum(d["period_sale_qty"] for d in fc_new)
        prev_tot = sum(d["period_sale_qty"] for d in fp_new)
        tot_all  = sum(d["period_sale_qty"] for d in fc_all)
        new_q    = cur_tot
        carry_q  = sum(d["period_sale_qty"] for d in fc_carry)

        # ① 그룹별 YoY — 수치 비교해서 가장 특징적인 것만
        grp_cur  = {g: sum(d["period_sale_qty"] for d in fc_new  if d["group"] == g) for g in GROUPS}
        grp_prev = {g: sum(d["period_sale_qty"] for d in fp_new  if d["group"] == g) for g in GROUPS}
        grp_yoy  = []
        for g in GROUPS:
            c, p = grp_cur[g], grp_prev[g]
            if c > 0 or p > 0:
                pct = round((c - p) / p * 100, 1) if p > 0 else None
                grp_yoy.append((g, c, p, pct))
        grp_yoy.sort(key=lambda x: abs(x[3] or 0), reverse=True)  # 변화폭 큰 순

        for g, c, p, pct in grp_yoy[:2]:
            if pct is None: continue
            lbl = GROUP_LABELS.get(g, g)
            if pct >= 20:
                pts.append(f"{lbl} 전년 동기 대비 +{pct}% 호조 — {p:,}개→{c:,}개, 수요 급증")
            elif pct >= 5:
                pts.append(f"{lbl} 전년 동기 대비 +{pct}% 증가 — {p:,}개→{c:,}개")
            elif pct <= -20:
                pts.append(f"{lbl} 전년 대비 {pct}% 급감 — {p:,}개→{c:,}개, 수요 부진 원인 점검 필요")
            elif pct <= -5:
                pts.append(f"{lbl} 전년 대비 {pct}% 감소 — {p:,}개→{c:,}개")

        # ② 전체 YoY
        if prev_tot > 0:
            tot_yoy = round((cur_tot - prev_tot) / prev_tot * 100, 1)
            if abs(tot_yoy) >= 5:
                sign = f"+{tot_yoy}%" if tot_yoy >= 0 else f"{tot_yoy}%"
                pts.append(f"신상 전체 판매 전년 대비 {sign} — {prev_tot:,}개→{cur_tot:,}개")

        # ③ 신상 vs 이월 비율 — 전사 평균과 비교
        if tot_all > 0:
            nr = round(new_q / tot_all * 100)
            cr = round(carry_q / tot_all * 100)
            # 이월이 절반 초과면 특이
            if cr >= 60:
                pts.append(f"이월 비중 {cr}% — 신상 판매 부진, 재고 소진 중심 운영")
            elif nr >= 80:
                pts.append(f"신상(26SS) 집중도 {nr}% — 이월 영향 거의 없음, 신상 수요 강세")
            # 이월 중 특정 시즌 집중
            carry_by_ssn = {}
            for d in fc_carry:
                carry_by_ssn[d["season"]] = carry_by_ssn.get(d["season"], 0) + d["period_sale_qty"]
            if carry_by_ssn:
                top_ssn = max(carry_by_ssn, key=carry_by_ssn.get)
                top_ssn_q = carry_by_ssn[top_ssn]
                if top_ssn_q > 0 and carry_q > 0:
                    ssn_pct = round(top_ssn_q / carry_q * 100)
                    if ssn_pct >= 60 and cr >= 20:
                        pts.append(f"이월 중 {top_ssn} 상품이 {ssn_pct}% 집중 — {top_ssn_q:,}개 판매")

        # ④ 실판매금액 할인율 (최초판매금액 기준)
        first_amt = sum(d["period_first_amt"] for d in fc_new)
        net_amt   = sum(d["period_net_amt"]   for d in fc_new)
        if first_amt > 0:
            disc = round((first_amt - net_amt) / first_amt * 100, 1)
            if disc >= 30:
                pts.append(f"신상 평균 할인율 {disc}% — 고할인 집중, 최초판매가 대비 실판 괴리 큼")
            elif disc <= 5:
                pts.append(f"신상 평균 할인율 {disc}% — 사실상 정가 판매, 할인 없이 수요 흡수 중")
            # 할인율 높은 SKU 개수
            high_disc_cnt = sum(
                1 for d in fc_new
                if d["period_first_amt"] > 0 and
                   (d["period_first_amt"] - d["period_net_amt"]) / d["period_first_amt"] >= 0.3
                   and d["period_sale_qty"] > 0
            )
            if high_disc_cnt >= 3:
                pts.append(f"30% 이상 고할인 SKU {high_disc_cnt}개 — 특정 품번 집중 할인 중")

        # ⑤ 최다판매 vs 최저판매 SKU 격차 (집중도)
        sorted_new = sorted(fc_new, key=lambda x: -x["period_sale_qty"])
        if len(sorted_new) >= 5 and sorted_new[0]["period_sale_qty"] > 0:
            top1_q = sorted_new[0]["period_sale_qty"]
            top1_ratio = round(top1_q / new_q * 100) if new_q > 0 else 0
            if top1_ratio >= 30:
                pts.append(f"TOP1 품번({sorted_new[0]['item_code']})이 신상 판매 {top1_ratio}% 차지 — 단일 SKU 쏠림 주의")

        # ⑥ 전전주 대비 판매 급변 SKU — QR 검토 권고
        if pprev_lookup:
            wc = compute_wow_changes(fc_all, pprev_lookup)
            qr_codes = [f"{r['item_code']}({r['change']:+.0f}%)" for r in wc["surge"] if r["qr_candidate"]]
            if qr_codes:
                pts.append(f"전전주 대비 급증(QR 검토 권고) — {', '.join(qr_codes[:4])}")
            drop_codes = [f"{r['item_code']}({r['change']:+.0f}%)" for r in wc["drop"]]
            if drop_codes:
                pts.append(f"전전주 대비 급감 주의 — {', '.join(drop_codes[:3])}")

        result[b] = pts[:6]
    return result

def build_view(ic, ip, brand, pprev_lookup):
    fc, fp = fil_b(ic, brand), fil_b(ip, brand)
    return {
        "summary":     compute_summary(fc),
        "brief":       compute_brief(ic, ip, brand, pprev_lookup),
        "insight":     compute_insight(ic, ip, brand, pprev_lookup),
        "chart":       compute_chart(fc, fp),
        "matrix":      compute_matrix(fc),
        "alarms":      compute_alarms(fc),
        "wow_changes": compute_wow_changes(fc, pprev_lookup),
        "spikes":      compute_spikes(fc, pprev_lookup),
        "bag_compare": compute_bag_compare(fc, fp),
        "detail":      compute_detail(fc),
    }

